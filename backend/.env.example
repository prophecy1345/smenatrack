# Скопируйте в backend/.env и подставьте свои значения.
# Настоящий .env в репозиторий не коммитится (см. .gitignore из модуля 3).

DB_HOST=localhost
DB_PORT=5432
DB_USER=smenatrack
DB_PASSWORD=smenatrack_password
DB_NAME=smenatrack

# Любая случайная строка: openssl rand -hex 32
JWT_SECRET=замените_на_свой_секрет

# Адрес frontend — нужен для CORS (модуль 10)
FRONTEND_URL=http://localhost:5173
